{
  "buildCommand": "pnpm install && pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/license-admin run build",
  "outputDirectory": "artifacts/license-admin/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dmh-license-api.onrender.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
